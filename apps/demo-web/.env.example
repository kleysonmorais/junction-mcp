# Junction sandbox API key (sk_us_* / sk_eu_*) — used by /mcp-demo and /api/chat.
# Get one at https://app.junction.com (sandbox team → API keys).
JUNCTION_API_KEY=sk_us_your_key_here

# Junction sandbox base URL (defaults to US sandbox if unset).
# JUNCTION_BASE_URL=https://api.sandbox.us.junction.com

# LLM provider key for the Agent Chat demo (/api/chat).
# The agent layer is provider-agnostic (Vercel AI SDK). Set at least one key.
# If both are set, Anthropic wins unless LLM_PROVIDER is set below.
# ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_key_here

# Optional: force a provider ("anthropic" or "openai"). Defaults to whichever
# API key is present (Anthropic preferred when both are set).
# LLM_PROVIDER=anthropic

# Optional: override the chat model. Defaults per provider
# (claude-opus-4-8 for anthropic, gpt-4o for openai).
# CHAT_MODEL=claude-opus-4-8

# Optional: comma-separated extra origins allowed to call the MCP endpoints
# (localhost and the deployment's own origin are always allowed).
# ALLOWED_ORIGINS=https://example.com

# Public site URL used for SEO metadata (canonical links, OG/Twitter images, sitemap).
# Defaults to http://localhost:3000 if unset.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
