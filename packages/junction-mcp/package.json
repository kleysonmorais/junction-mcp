{
  "name": "junction-mcp",
  "version": "0.1.0",
  "description": "Transport-agnostic MCP server core exposing Junction's wearable and lab data to AI agents.",
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "bin"
  ],
  "bin": {
    "junction-mcp": "bin/stdio.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "stdio": "tsx bin/stdio.ts",
    "smoke": "tsx scripts/smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
