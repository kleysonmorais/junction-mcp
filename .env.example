# Junction sandbox API key (sk_us_* / sk_eu_*) — used by /mcp-demo and /api/chat.
# Get one at https://app.junction.com (sandbox team → API keys).
JUNCTION_API_KEY=sk_us_your_key_here

# Junction sandbox base URL (defaults to US sandbox if unset).
# JUNCTION_BASE_URL=https://api.sandbox.us.junction.com

# LLM provider key for the Agent Chat demo (/api/chat).
# The agent layer is provider-agnostic (Vercel AI SDK) — Anthropic is the default provider.
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Optional: override the chat model (defaults to claude-opus-4-8).
# CHAT_MODEL=claude-opus-4-8

# Optional: comma-separated extra origins allowed to call the MCP endpoints
# (localhost and the deployment's own origin are always allowed).
# ALLOWED_ORIGINS=https://example.com
