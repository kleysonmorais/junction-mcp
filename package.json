{
  "name": "junction-mcp-monorepo",
  "version": "0.1.0",
  "description": "Monorepo for junction-mcp: a publishable MCP server core, a Next.js demo UI, and synthetic sandbox data tooling.",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "pnpm": ">=11.9.0",
    "node": ">=20"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter demo-web dev",
    "build": "pnpm --filter demo-web build",
    "start": "pnpm --filter demo-web start",
    "lint": "pnpm --filter demo-web lint",
    "stdio": "pnpm --filter junction-mcp stdio",
    "smoke": "pnpm --filter junction-mcp smoke",
    "setup:sandbox": "pnpm --filter synthetic-data setup",
    "typecheck": "pnpm -r typecheck"
  }
}
